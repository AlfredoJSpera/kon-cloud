{
	"compilerOptions": {
		//! TypeScript paths shorthand
		"baseUrl": ".",
		"paths": {
			"@lib/*": ["lib/*"],
			"@generated/*": ["generated/*"],
			"@middleware/*": ["src/middleware/*"]
		},

		"types": ["node"],

		//! Required by Prisma
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "es2025",
		"strict": true,
		"esModuleInterop": true,
		"ignoreDeprecations": "6.0"
	}
}
