{
	"compilerOptions": {
		//! TypeScript paths shorthand
		"paths": {
			"@generated/*": ["./generated/*"],
			"@interfaces/*": ["./interfaces/*"],
			"@errors/*": ["./src/errors/*"],
			"@lib/*": ["./src/lib/*"],
			"@middleware/*": ["./src/middleware/*"],
			"@routes/*": ["./src/routes/*"],
			"@utils/*": ["./src/utils/*"]
		},

		"types": ["node"],

		//! Required by Prisma
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "es2025",
		"strict": true,
		"esModuleInterop": true,
		"ignoreDeprecations": "6.0"
	}
}
