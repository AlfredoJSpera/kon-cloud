{
	"compilerOptions": {
		//! TypeScript paths shorthand
		"baseUrl": ".",
		"paths": {
			"@lib/*": ["lib/*"],
			"@errors/*": ["errors/*"],
			"@generated/*": ["generated/*"],
			"@interfaces/*": ["interfaces/*"],
			"@middleware/*": ["src/middleware/*"],
			"@routes/*": ["src/routes/*"],
			"@utils/*": ["src/utils/*"]
		},

		"types": ["node"],

		//! Required by Prisma
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "es2025",
		"strict": true,
		"esModuleInterop": true,
		"ignoreDeprecations": "6.0"
	}
}
